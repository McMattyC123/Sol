# At least one RPC (Helius + QuickNode rotate automatically; SOLANA_RPC_URL alone also works)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
QUICKNODE_RPC_URL=https://example.solana-mainnet.quiknode.pro/token/
# Fallback if only one provider:
# SOLANA_RPC_URL=https://

# Wallets: JSON array of { "label", "keypairPath", "group": "buyers"|"sellers", "role": "buyer"|"seller" }
WALLETS_CONFIG=./data/wallets.example.json

# Primary keypair (transfer command)
SOLANA_KEYPAIR_PATH=

# Jito gRPC (defaults to mainnet.block-engine.jito.wtf)
BLOCK_ENGINE_URL=mainnet.block-engine.jito.wtf
JITO_AUTH_KEYPAIR_PATH=
JITO_TIP_LAMPORTS=10000
USE_JITO=true

# Simulation
SIMULATION_CONFIG=./data/simulation.json
SIM_MINT=
SIM_INTERVAL_MS=15000
SIM_JITTER_MS=3000

# Optional
SLIPPAGE_BPS=100
COMMITMENT=confirmed
SKIP_PREFLIGHT=false
CLI_MASTER_PASSWORD=

# Web server (Express dashboard + API; Railway sets PORT automatically)
PORT=3001

# Optional cluster: mainnet | devnet | testnet. If unset, legacy mode (no mainnet gate).
# Railway mainnet live: set TRADING_NETWORK=mainnet and ALLOW_MAINNET_LIVE=true
# TRADING_NETWORK=mainnet
# ALLOW_MAINNET_LIVE=true
