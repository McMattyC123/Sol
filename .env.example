# Pick one template and copy to ".env" (do not commit .env):
#   cp .env.example.devnet .env
#   cp .env.example.mainnet .env
#
# Devnet:  .env.example.devnet  — TRADING_NETWORK=devnet, devnet RPC + Jito host hints
# Mainnet: .env.example.mainnet — TRADING_NETWORK=mainnet + ALLOW_MAINNET_LIVE gate
#
# Minimal reminder (see templates for full variable list):
# WALLETS_CONFIG=./data/wallets.json
# SOLANA_KEYPAIR_PATH=./data/keys/primary.json
