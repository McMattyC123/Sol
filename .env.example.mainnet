# Mainnet — copy only when you intend real funds (cp .env.example.mainnet .env)
# Live swaps require explicit opt-in below.

TRADING_NETWORK=mainnet
ALLOW_MAINNET_LIVE=false
# Set to true only when you deliberately enable transfers, swaps, and simulation on mainnet.

HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# QUICKNODE_RPC_URL=https://example.solana-mainnet.quiknode.pro/YOUR_TOKEN/

WALLETS_CONFIG=./data/wallets.json
SOLANA_KEYPAIR_PATH=./data/keys/primary.json
JITO_AUTH_KEYPAIR_PATH=./data/keys/primary.json

BLOCK_ENGINE_URL=mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=10000
USE_JITO=true

SIMULATION_CONFIG=./data/simulation.json
SIM_MINT=
SIM_INTERVAL_MS=15000
SIM_JITTER_MS=3000

SLIPPAGE_BPS=100
COMMITMENT=confirmed
SKIP_PREFLIGHT=false
BUNDLE_TRANSACTION_LIMIT=5

CLI_MASTER_PASSWORD=
PORT=3001
