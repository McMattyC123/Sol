# Devnet — copy to .env for local / research (cp .env.example.devnet .env)
# Jupiter swap API uses cluster=devnet when TRADING_NETWORK=devnet

TRADING_NETWORK=devnet
ALLOW_MAINNET_LIVE=false

# RPC (set at least one)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_DEVNET_KEY
# HELIUS_WSS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_DEVNET_KEY
# QUICKNODE_RPC_URL=https://example.solana-devnet.quiknode.pro/YOUR_TOKEN/
# QUICKNODE_WSS_URL=wss://example.solana-devnet.quiknode.pro/YOUR_TOKEN/
# SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WSS_URL=wss://api.devnet.solana.com

WALLETS_CONFIG=./data/wallets.json
SOLANA_KEYPAIR_PATH=./data/keys/primary.json
JITO_AUTH_KEYPAIR_PATH=./data/keys/primary.json

# Jito block engine (devnet). Verify regional URL in current Jito searcher / docs.
BLOCK_ENGINE_URL=amsterdam.devnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=1000
USE_JITO=true

SIMULATION_CONFIG=./data/simulation.json
SIM_MINT=
SIM_INTERVAL_MS=15000
SIM_JITTER_MS=3000

SLIPPAGE_BPS=200
COMMITMENT=confirmed
SKIP_PREFLIGHT=false
BUNDLE_TRANSACTION_LIMIT=5

CLI_MASTER_PASSWORD=
PORT=3001
